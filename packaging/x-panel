#!/usr/bin/env bash
set -Eeuo pipefail

ENV_FILE=/etc/xpanel/xpanel.env
DATA_DIR=${XPANEL_DATA_DIR:-/var/lib/xpanel}

require_root() {
  if [[ ${EUID} -ne 0 ]]; then
    echo "Please run as root: sudo x-panel" >&2
    exit 1
  fi
}

read_default() {
  local prompt=$1 default=$2 value
  read -r -p "${prompt} [${default}]: " value || true
  printf '%s' "${value:-$default}"
}

write_env() {
  local port=$1
  install -d -m 0755 /etc/xpanel
  cat >"${ENV_FILE}" <<EOF
XPANEL_DATA_DIR=${DATA_DIR}
XPANEL_LISTEN=127.0.0.1:${port}
XPANEL_XRAY_BINARY=/opt/xpanel/bin/xray
XPANEL_XRAY_CONFIG=${DATA_DIR}/xray/config.json
XPANEL_RELOAD_COMMAND=/usr/bin/sudo /usr/bin/systemctl restart xpanel-xray.service
EOF
}

current_port() {
  if [[ -f "${ENV_FILE}" ]]; then
    awk -F= '/^XPANEL_LISTEN=/{print $2}' "${ENV_FILE}" | awk -F: '{print $NF}'
  else
    echo "8080"
  fi
}

set_port() {
  local port
  port=$(read_default "Panel local port" "$(current_port)")
  if ! [[ "${port}" =~ ^[0-9]+$ ]] || (( port < 1 || port > 65535 )); then
    echo "Invalid port: ${port}" >&2
    return 1
  fi
  write_env "${port}"
  systemctl daemon-reload
  systemctl restart xpanel
  echo "Panel port updated. Use: ssh -L 18080:127.0.0.1:${port} root@your-server"
}

set_admin() {
  local username password
  username=$(read_default "Admin username" "admin")
  read -r -s -p "Admin password [admin123456]: " password || true
  echo
  password=${password:-admin123456}
  XPANEL_DATA_DIR="${DATA_DIR}" /usr/local/bin/xpanel user set --username "${username}" --password "${password}"
  systemctl restart xpanel
  echo "Administrator account updated."
}

status() {
  systemctl --no-pager --full status xpanel || true
  systemctl --no-pager --full status xpanel-xray || true
  ss -lntp | grep -E '(:8080|xpanel|xray)' || true
}

menu() {
  while true; do
    cat <<EOF

XPanel Control Menu
-------------------
1) Show service status
2) Change panel port
3) Change administrator username/password
4) Restart panel
5) Restart Xray
6) Show access hint
0) Exit
EOF
    read -r -p "Select an option: " choice
    case "${choice}" in
      1) status ;;
      2) set_port ;;
      3) set_admin ;;
      4) systemctl restart xpanel && echo "Panel restarted." ;;
      5) systemctl restart xpanel-xray && echo "Xray restarted." ;;
      6) echo "SSH tunnel: ssh -L 18080:127.0.0.1:$(current_port) root@your-server"; echo "Browser: http://127.0.0.1:18080/" ;;
      0) exit 0 ;;
      *) echo "Invalid option." ;;
    esac
  done
}

require_root
case "${1:-menu}" in
  menu) menu ;;
  port) set_port ;;
  user) set_admin ;;
  status) status ;;
  *) echo "Usage: x-panel [menu|port|user|status]" >&2; exit 2 ;;
esac
